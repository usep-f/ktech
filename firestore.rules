rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: a user can read and write only their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Appointments collection: a user can read and write only their own appointments
    match /appointments/{appointmentId} {
      // allow create if they are setting their own userId
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // allow read, update, delete if the document belongs to them
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}